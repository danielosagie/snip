{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "bun run build",
  "outputDirectory": "dist/client",
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/downloads/snip-desktop\\.pkg",
      "status": 302,
      "headers": {
        "Location": "https://github.com/danielosagie/snip/releases/latest/download/snip-desktop.pkg"
      }
    },
    {
      "src": "/downloads/snip-desktop\\.dmg",
      "status": 302,
      "headers": {
        "Location": "https://github.com/danielosagie/snip/releases/latest/download/snip-desktop.dmg"
      }
    },
    {
      "src": "/downloads/snip-desktop-x64\\.dmg",
      "status": 302,
      "headers": {
        "Location": "https://github.com/danielosagie/snip/releases/latest/download/snip-desktop-x64.dmg"
      }
    },
    { "src": "/(.*)", "dest": "/_shell.html" }
  ]
}
