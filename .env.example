# ─── Required: Convex + Clerk ─────────────────────────────────────────────────
# Convex deployment URL — written automatically by `bunx convex dev`.
VITE_CONVEX_URL=
VITE_CONVEX_SITE_URL=
CONVEX_DEPLOYMENT=

# Clerk auth — sign up free at https://clerk.com
VITE_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ─── Optional: leave blank for demo mode ──────────────────────────────────────
# Setting STRIPE_SECRET_KEY enables real payments. Leaving it blank activates
# the "simulate paying" button on paywalled share links.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe price IDs for the SaaS subscription tiers. The env var names
# are preserved from the legacy basic/pro layout to avoid rotating the
# already-configured Stripe products:
#   STRIPE_PRICE_BASIC_MONTHLY → "Basic" plan ($20/mo · 2 TB)
#   STRIPE_PRICE_PRO_MONTHLY   → "Pro"   plan ($50/mo · 5 TB)
# Free tier (20 GB) requires no Stripe price. Workspace checkout
# (convex/workspaceBillingActions.ts) and the legacy per-team
# checkout (convex/billing.ts) both read these.
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_PRO_MONTHLY=
# Annual prepay — 17% off (10 months for the price of 12). Optional;
# leave blank to disable the annual toggle in checkout.
STRIPE_PRICE_BASIC_ANNUAL=
STRIPE_PRICE_PRO_ANNUAL=
# Platform fee in basis points charged on every paywalled-delivery
# payment that flows through Stripe Connect to the team's connected
# account. 100 = 1%, 250 = 2.5%, etc. Capped at 5000 (50%) by the
# code so a typo can't accidentally consume the whole payment.
#
# At 100 (1%) and ~$50k/mo of agency client deliveries, that's $500/mo
# in net-new platform revenue per heavy customer — at zero incremental
# COGS to us. See `computeApplicationFee` in convex/paymentsActions.ts.
#
# Default 100 here is suggested for production; bump or leave 0 for
# self-host / dev as you prefer.
VIDEOINFRA_PLATFORM_FEE_BASIS_POINTS=100

# Mux — sign up at https://mux.com (free trial). Required for real uploads.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_WEBHOOK_SECRET=
# Required for paywalled signed playback (separate signing keys in Mux).
MUX_SIGNING_KEY=
MUX_PRIVATE_KEY=

# Cloudflare Stream — alternate playback provider, ~10× cheaper than Mux
# on encode + delivery. The per-video `playbackProvider` field selects
# which provider owns each row; leave the default (Mux) unless you've
# wired Stream end-to-end. See convex/providers/playbackProvider.ts.
#
# CF_STREAM_API_TOKEN: a Cloudflare API token with the "Stream: Edit"
# permission. CF_STREAM_ACCOUNT_ID: your Cloudflare account id.
CF_STREAM_ACCOUNT_ID=
CF_STREAM_API_TOKEN=
# CF_STREAM_WEBHOOK_SECRET: do NOT invent this. Register the webhook
# via the API and save the `secret` it returns. notificationUrl is your
# Convex SITE url (the .convex.site one, = VITE_CONVEX_SITE_URL) plus
# the route path /webhooks/cf-stream:
#
#   curl -X PUT \
#     --header 'Authorization: Bearer <CF_STREAM_API_TOKEN>' \
#     https://api.cloudflare.com/client/v4/accounts/<CF_STREAM_ACCOUNT_ID>/stream/webhook \
#     --data '{"notificationUrl":"https://<your>.convex.site/webhooks/cf-stream"}'
#
# The JSON response includes result.secret — set that here. It's what
# convex/cloudflareStreamActions.ts uses to verify the Webhook-Signature
# header (HMAC-SHA256 over `${time}.${body}`).
CF_STREAM_WEBHOOK_SECRET=
# Default provider for NEW uploads. "mux" (default) or "cloudflare_stream".
# When set, every new upload uses this provider regardless of tier.
PLAYBACK_PROVIDER_DEFAULT=mux

# Tier-based routing — when "true", free-tier uploads go to Cloudflare
# Stream and paid tiers stay on Mux. Mutually exclusive with
# PLAYBACK_PROVIDER_DEFAULT (the explicit value wins).
PLAYBACK_PROVIDER_BY_TIER=false

# Lazy encoding — skip Mux ingest at upload, defer to first watch.
# "never" (default), "free" (defer free-tier only), "always". Cuts COGS
# on the long tail of footage that's uploaded but never opened.
LAZY_ENCODE_DEFAULT=never

# ─── Storage: pick ONE ────────────────────────────────────────────────────────
# Cloudflare R2 (recommended — no egress fees for desktop sync)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_REGION=auto

# Or Railway S3 (the original setup)
# RAILWAY_ACCESS_KEY_ID=
# RAILWAY_SECRET_ACCESS_KEY=
# RAILWAY_ENDPOINT=
# RAILWAY_BUCKET_NAME=
# RAILWAY_PUBLIC_URL=
# RAILWAY_REGION=us-east-1

# ─── Optional: per-user scoped storage credentials ────────────────────────────
# Without these, the desktop gets the shared bucket key (team members only).
# Setting them makes convex/storageCredentials vend short-lived credentials
# scoped to each user's projects/<teamSlug>/ prefixes — the storage-side ACL
# that makes folder permissions un-bypassable.
#
# R2: a Cloudflare API token with R2 temp-credential permission + account id.
#     Reuses R2_ACCESS_KEY_ID above as the parent key.
# R2_ACCOUNT_ID=
# R2_API_TOKEN=
#
# S3 / MinIO: a role to AssumeRole into, scoped per-session via STS.
# STS_ROLE_ARN=
# STS_ENDPOINT=
# STS_REGION=
