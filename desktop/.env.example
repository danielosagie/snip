# Desktop build-time config (Vite, embedded at `vite build` time).
#
# ALL OPTIONAL — desktop/src/config.ts ships correct production defaults baked
# in, so a plain `bun run build:dmg` / `bun run release` already points at the
# live web app. Set these only for staging or self-host builds.
#
# IMPORTANT: VITE_WEB_ORIGIN is the domain the pairing flow opens
# (/connect-desktop). If it points at a dead domain, pairing can never complete
# — the desktop opens the browser there and polls forever. The default below is
# the live project URL; keep it correct whenever the web app moves.

# Convex deployment the desktop talks to (must match the web app's deployment).
# VITE_CONVEX_URL=https://confident-starling-497.convex.cloud

# Clerk publishable key (client-public; must match the Clerk instance the Convex
# deployment uses, otherwise the pairing sign-in ticket won't redeem).
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx

# Web origin for the device-pairing hand-off.
# VITE_WEB_ORIGIN=https://snipfilm.vercel.app
